# Margin IQ — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# NEVER set VITE_SUPABASE_SERVICE_ROLE_KEY — service role must not be in client code.

# Stripe Billing — server/Edge Function secrets only. NEVER prefix with VITE_.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# SITE_URL=http://localhost:8085

# E2E Testing (optional — for npm run test:e2e)
E2E_BASE_URL=http://localhost:8085
E2E_EMAIL=
E2E_PASSWORD=
